{
  "realm": "myapps",
  "enabled": true,
  "displayName": "Raks Apps SSO",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard application user"
      }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "splitsek-ui",
      "name": "SplitSek UI",
      "description": "SplitSek Angular frontend (localhost:4200)",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "rootUrl": "http://localhost:4200",
      "baseUrl": "http://localhost:4200",
      "redirectUris": ["http://localhost:4200/*"],
      "webOrigins": ["http://localhost:4200"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email"]
    },
    {
      "clientId": "demo-app",
      "name": "Demo App 2",
      "description": "Second app to test SSO (localhost:4201)",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "rootUrl": "http://localhost:4201",
      "baseUrl": "http://localhost:4201",
      "redirectUris": ["http://localhost:4201/*"],
      "webOrigins": ["http://localhost:4201"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email"]
    },
    {
      "clientId": "splitsek-api",
      "name": "SplitSek API",
      "description": "Spring Boot resource server — validates Keycloak JWTs",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "bearerOnly": true,
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email"]
    }
  ],
  "users": [
    {
      "username": "alice",
      "email": "alice@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Alice",
      "lastName": "Demo",
      "realmRoles": ["user"],
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ]
    },
    {
      "username": "bob",
      "email": "bob@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Bob",
      "lastName": "Demo",
      "realmRoles": ["user"],
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ]
    }
  ]
}
